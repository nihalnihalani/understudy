# ───── Gemini (three-model synthesis brain) ─────
GEMINI_API_KEY=

# ───── TinyFish (CLI + Agent Skills; Mac Mini browser pool) ─────
TINYFISH_API_KEY=

# ───── InsForge 2.0 (Remote OAuth MCP + PostgREST + Model Gateway) ─────
INSFORGE_OAUTH_CLIENT_ID=
INSFORGE_OAUTH_CLIENT_SECRET=

# ───── Redis 8 (AMS + Vector Sets int8 + LangCache) ─────
REDIS_URL=redis://localhost:6379

# ───── Wundergraph Cosmo (MCP Gateway + Dream Query + EDFS) ─────
COSMO_ROUTER_URL=http://localhost:3002

# ───── Supply chain (Chainguard + Fulcio + Rekor via GHCR) ─────
GHCR_TOKEN=
CHAINGUARD_REGISTRY=cgr.dev/chainguard

# ───── Runtime (Fly.io Machines) ─────
FLY_API_TOKEN=

# ───── Demo controls ─────
# DEMO_MODE: live | replay | hybrid   (architecture.md §14)
DEMO_MODE=live
# COSMO_MOCK: when true, cosmo-mcp-driver returns canned Dream Query output (for offline dev).
COSMO_MOCK=false

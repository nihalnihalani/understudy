# Understudy — environment variables
#
# Copy to `.env` and fill in the blanks (`.env` is .gitignored, `.env.example` is committed).
# Docker Compose auto-loads `.env` from this directory.
# Supply-chain values (PIP_INDEX_URL, NPM_CHAINGUARD_AUTH, UV_INDEX_URL) live in
# `.env.chainguard` instead — generated by scripts/chainguard_init.sh, never committed.
#
# Every var below maps to a specific reader in the code; see comments.
# Keys marked (required) crash the app / refuse to boot if unset.

# ═══════════════════════════════════════════════════════════════════════════
# Gemini — three-model synthesis brain (architecture.md §3, §10, §11)
# ═══════════════════════════════════════════════════════════════════════════

# (required) Google Gemini API key for 3.1 Flash-Lite / 3.1 Pro / 3 Flash.
# Reader: apps/api/main.py, apps/synthesis-worker/gemini_client.py
GEMINI_API_KEY=
# google-genai SDK reads GOOGLE_API_KEY internally; keep it in sync with GEMINI_API_KEY.
GOOGLE_API_KEY=

# Hybrid-mode budget (seconds) before falling back to replay / InsForge Model Gateway.
# Reader: apps/synthesis-worker/gemini_client.py
HYBRID_LIVE_BUDGET_S=8.0

# ═══════════════════════════════════════════════════════════════════════════
# TinyFish — CLI + Agent Skills; browser execution on TinyFish's hosted cloud
# ═══════════════════════════════════════════════════════════════════════════

# (required in prod) API key for the TinyFish hosted browser cloud.
# Reader: apps/api/main.py (manifest validation), `tinyfish run` subprocess
TINYFISH_API_KEY=
# Optional path override for the TinyFish binary (defaults to PATH lookup).
# Reader: apps/agent-template/src/tinyfish/cli.ts
TINYFISH_BIN=tinyfish

# ═══════════════════════════════════════════════════════════════════════════
# InsForge 2.0 — REST + Remote MCP + PostgREST + Model Gateway
# ═══════════════════════════════════════════════════════════════════════════

# InsForge 2.0 project connection (dashboard → Project Settings → General).
# Auth: `Authorization: Bearer ${INSFORGE_API_KEY}` against ${INSFORGE_URL}/api/…
# Reader: apps/api/store.py, apps/synthesis-worker/insforge_writer.py
INSFORGE_URL=
INSFORGE_API_KEY=

# InsForge Model Gateway URL — fallback route when Gemini returns 429.
# Reader: apps/synthesis-worker/gemini_client.py  _call_insforge_gateway
MODEL_GATEWAY_URL=

# ═══════════════════════════════════════════════════════════════════════════
# Redis 8 — AMS + int8 Vector Sets + LangCache + replay cache
# ═══════════════════════════════════════════════════════════════════════════

# Connection URL. Default is the docker-compose service.
# Reader: apps/api/redis_client.py, apps/synthesis-worker/main.py,
#         understudy/memory/client.py, scripts/prewarm_demo.py, agent-template
REDIS_URL=redis://localhost:6379/0

# Optional dedicated endpoint for Redis LangCache (managed service). If unset,
# LangCache lookups go through the same Redis as everything else.
# Reader: apps/synthesis-worker/langcache.py
REDIS_LANGCACHE_URL=

# ═══════════════════════════════════════════════════════════════════════════
# Wundergraph Cosmo — Dream Query + federated router + EDFS
# ═══════════════════════════════════════════════════════════════════════════

# Federated router base URL. Default targets the docker-compose service.
# Reader: apps/api/main.py, apps/cosmo-router/main.py
COSMO_ROUTER_URL=http://localhost:4000

# When 1, the Cosmo MCP driver returns canned Dream Query output — good for
# offline dev and the hermetic demo path.
# Reader: apps/cosmo-mcp-driver/driver.py, apps/synthesis-worker/pipeline.py
COSMO_MOCK=0

# MCP transport: `stdio` shells out to `wgc mcp serve`; `cloud` hits the hosted MCP.
# Reader: apps/cosmo-mcp-driver/driver.py
COSMO_TRANSPORT=stdio
# Only consulted when COSMO_TRANSPORT=cloud.
COSMO_CLOUD_MCP_URL=https://cosmo-mcp.wundergraph.com/v1/rpc
COSMO_API_TOKEN=

# Cosmo Cloud API key — distinct from COSMO_API_TOKEN above. Used by the
# wgc CLI (which is the canonical name) and by anything shelling out to
# wgc: scripts/register_agent_subgraph.sh and apps/synthesis-worker/cosmo_writer.py
# (Cosmo Connect Trusted Documents push). Leave blank to force offline mode —
# subgraph register + ops push will write files locally and skip cloud calls.
# Get it from `wgc auth login` or Cosmo Studio → Settings → API Keys.
COSMO_API_KEY=

# Cosmo Connect — Trusted Documents push (apps/synthesis-worker/cosmo_writer.py)
# COSMO_FEDERATED_GRAPH_NAME: the federated graph in Cosmo Cloud that owns the
# trusted ops; one per project. COSMO_NAMESPACE: graph namespace ('default' is
# fine for most teams). COSMO_OPERATIONS_DIR: where the synthesis worker writes
# generated .graphql operation files; the router mounts this read-only.
COSMO_FEDERATED_GRAPH_NAME=understudy
COSMO_NAMESPACE=default
COSMO_OPERATIONS_DIR=apps/cosmo-router/operations

# Cosmo Studio URL surfaced in the UI.
# Reader: apps/web/src/pages/DreamQuery.tsx (also VITE_STUDIO_URL below)
STUDIO_URL=https://cosmo.wundergraph.com/studio

# EDFS brokers (Kafka / NATS) for event-driven fields. Leave unset if unused.
# Reader: apps/cosmo-router/config.yaml (docker-compose.yml wires these through)
EDFS_KAFKA_BROKERS=
EDFS_KAFKA_SASL_USERNAME=
EDFS_KAFKA_SASL_PASSWORD=
EDFS_NATS_URL=
EDFS_NATS_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════
# Supply chain — Chainguard + SLSA L2 + cosign (Fulcio / Rekor)
# ═══════════════════════════════════════════════════════════════════════════

# (required in prod) Token for pushing/pulling from GHCR during cosign verify.
GHCR_TOKEN=
CHAINGUARD_REGISTRY=cgr.dev/chainguard

# Enables keyless cosign via OIDC (GitHub Actions Fulcio path).
# Readers: infra/fly/fly-start.sh, infra/fly/{fly.toml,agent.fly.toml.tmpl}
COSIGN_EXPERIMENTAL=1

# (required for preboot verify) Expected builder identity + OIDC issuer.
# Must match the GitHub Actions workflow path exactly.
COSIGN_CERT_IDENTITY=https://github.com/nihalnihalani/understudy/.github/workflows/release.yml@refs/heads/main
COSIGN_CERT_OIDC_ISSUER=https://token.actions.githubusercontent.com

# Image ref that preboot verifies. Fly.io sets this automatically from the
# deployed machine manifest; override for local testing.
# Readers: infra/fly/fly-start.sh, apps/agent-template/src/preboot/verify.ts
IMAGE_REF=
AGENT_IMAGE_REF=

# Dev-only escape hatch — set to 1 to skip the preboot cosign check.
# NEVER set this in prod.
# Reader: apps/agent-template/src/index.ts
SKIP_COSIGN_VERIFY=0

# ═══════════════════════════════════════════════════════════════════════════
# Chainguard Libraries secrets — GitHub Actions only
# ═══════════════════════════════════════════════════════════════════════════
# These power the Chainguard PyPI + npm mirrors at build time. For local
# Docker builds, source .env.chainguard (generated by
# scripts/chainguard_init.sh). For CI, set these as repo secrets at
# Settings → Secrets and variables → Actions.
#
#   CHAINGUARD_PYTHON_USERNAME      (Chainguard identity_id, '/' replaced by '_')
#   CHAINGUARD_PYTHON_PASSWORD      (token)
#   CHAINGUARD_JAVASCRIPT_USERNAME  (identity_id, '/' replaced by '_')
#   CHAINGUARD_JAVASCRIPT_PASSWORD  (token)
#
# InsForge CI persistence — GitHub Actions only
# ---------------------------------------------------------------------------
# After cosign/Rekor land the supply-chain proof, the release workflow POSTs
# image / slsa_attestation / sbom rows into InsForge so the frontend renders
# real CI metadata (not fixtures). See docs/chainguard-libraries.md for the
# full setup. Set these as repo secrets at
# Settings → Secrets and variables → Actions.
#
#   INSFORGE_URL                    (e.g. https://your-project.insforge.io)
#   INSFORGE_API_KEY                (Bearer token for /api/database/records/*)

# ═══════════════════════════════════════════════════════════════════════════
# Fly.io — deployment controls
# ═══════════════════════════════════════════════════════════════════════════

# (required to deploy) flyctl auth token.
FLY_API_TOKEN=
# Overrides for scripts/demo_mode_switch.sh.
FLY_SYNTH_APP=understudy-synthesis
FLY_ROUTER_APP=understudy-router

# ═══════════════════════════════════════════════════════════════════════════
# Runtime knobs
# ═══════════════════════════════════════════════════════════════════════════

# HTTP server listen port (Fly uses 8080; set 3000 for local parity with web).
# Readers: infra/fly/fly-start.sh, apps/agent-template/src/graphql/server.ts
PORT=8080

# Python logging level for the synthesis worker.
# Reader: apps/synthesis-worker/main.py
LOG_LEVEL=INFO

# Upload staging dir (ephemeral). Use a shared volume in prod.
# Reader: apps/api/main.py
UPLOAD_DIR=/tmp/understudy-recordings

# Consumer-group member id — unique per worker pod.
# Reader: apps/synthesis-worker/main.py
WORKER_ID=worker-1

# Cosmo router dev mode + log level (passed through docker-compose).
COSMO_ROUTER_DEV_MODE=false
COSMO_ROUTER_LOG_LEVEL=info

# CORS origin the router will allow.
# Reader: docker-compose.yml router service
FRONTEND_ORIGIN=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════════
# Web frontend (Vite; only VITE_* vars are exposed to the browser bundle)
# ═══════════════════════════════════════════════════════════════════════════

# Reader: apps/web/src/api/client.ts
VITE_API_BASE_URL=/api
# Reader: apps/web/src/pages/DreamQuery.tsx
VITE_STUDIO_URL=https://cosmo.wundergraph.com/studio

# ═══════════════════════════════════════════════════════════════════════════
# Demo controls — hermetic mode is non-negotiable for stage (architecture.md §14)
# ═══════════════════════════════════════════════════════════════════════════

# live | replay | hybrid
#   live   — every Gemini / Cosmo call hits the network (default; realistic)
#   replay — every call short-circuits to us:replay:* / dream:* / langcache keys
#   hybrid — live for HYBRID_LIVE_BUDGET_S seconds, then replay (stage default)
# Reader: apps/synthesis-worker/gemini_client.py, apps/api/main.py, worker main
DEMO_MODE=live

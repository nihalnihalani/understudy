.env
.env.local
.venv/
node_modules/
__pycache__/
*.pyc
.pytest_cache/
.DS_Store
dist/
build/
.vercel
.fly/

# Build + test artifacts — never commit these (one escaped in a prior commit; see revert).
.coverage
.coverage.*
*.tsbuildinfo
/package-lock.json
*.egg-info/

# Recordings — ignore all mp4s except the committed demo fixtures.
*.mp4
!fixtures/mp4/*.mp4

# Sigstore / cosign — prod signing is keyless via Fulcio; local dev keys stay local.
cosign.key
cosign.pub
cosign.*.key
*.cosign.key
sbom.spdx.json
rekor-entry.json

# Chainguard Libraries — pull-token credentials, never commit.
# Generated by scripts/chainguard_init.sh; tokens rotate every 30 days.
# See docs/chainguard-libraries.md.
pip.conf
!pip.conf.example
.env.chainguard
.npmrc
!.npmrc.example
chainguard-setup.md

# Local debug logs from scripts/dev-debug.sh
logs/

# State + sentinels written by ./run.sh (one-command dev launcher)
.runsh-state
.runsh-pip-installed-at

# InsForge & AI agent skills — local caches only; committed config under
# .claude/{agents,settings.json,skills} stays tracked.
.insforge
.agent
.agents
.augment
.claude/worktrees/
.claude/plugins/
.claude/cache/
.claude/local.*
.cline
.github/copilot*
.kilocode
.qoder
.qwen
.roo
.trae
.windsurf
understudy-default/

# Per-synth Trusted Document files written by apps/synthesis-worker/cosmo_writer.py
# (one subdir per agent_id). These are regenerated on every synthesis run; the
# router consumes the *services/* dir (proto + matched ops) instead.
apps/cosmo-router/operations/*/
!apps/cosmo-router/operations/.gitkeep

.env
.env.local
.venv/
node_modules/
__pycache__/
*.pyc
.pytest_cache/
.DS_Store
dist/
build/
.vercel
.fly/

# Build + test artifacts — never commit these (one escaped in a prior commit; see revert).
.coverage
.coverage.*
*.tsbuildinfo
/package-lock.json
*.egg-info/

# Recordings — ignore all mp4s except the committed demo fixtures.
*.mp4
!fixtures/mp4/*.mp4

# Sigstore / cosign — prod signing is keyless via Fulcio; local dev keys stay local.
cosign.key
cosign.pub
cosign.*.key
*.cosign.key
sbom.spdx.json
rekor-entry.json

# Chainguard Libraries — pull-token credentials, never commit.
# Generated by scripts/chainguard_init.sh; tokens rotate every 30 days.
# See docs/chainguard-libraries.md.
pip.conf
!pip.conf.example
.env.chainguard
apps/web/.npmrc
apps/agent-template/.npmrc
chainguard-setup.md

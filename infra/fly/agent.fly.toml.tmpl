# Per-generated-agent Fly.toml — rendered at synthesis time.
# architecture.md §5 (Generated Agent Runtime), §12 (Deployment).
#
# Jinja2 placeholders:
#   {{ agent_id }}        — uuid of the generated agent (used as app slug)
#   {{ image_digest }}    — sha256:... of the signed agent image
#   {{ graphql_port }}    — internal port the agent's GraphQL handler listens on
#   {{ ams_namespace }}   — Redis Agent Memory Server namespace (ams:agent:{id}:*)
#   {{ insforge_slot }}   — claimed warm-pool slot (0, 1, or 2)
#   {{ primary_region }}  — iad or sjc
#   {{ cosmo_endpoint }}  — federated endpoint for this agent's subgraph
#   {{ pre_warm }}        — bool (default false). When true, keeps one machine hot
#                           (min_machines_running=1, auto_stop_machines=off) to
#                           guarantee sub-second cold start. Demo agents only —
#                           normal synthesized agents should keep this false to
#                           stay cost-efficient.
#
# The pinned image is referenced by digest, never by tag — digest drift would
# break cosign verify which gates boot.

app = "understudy-agent-{{ agent_id }}"
primary_region = "{{ primary_region }}"

[build]
  image = "ghcr.io/nihalnihalani/understudy-agent-{{ agent_id }}@{{ image_digest }}"

[deploy]
  strategy = "rolling"

[env]
  AGENT_ID = "{{ agent_id }}"
  AMS_NAMESPACE = "{{ ams_namespace }}"
  INSFORGE_SLOT = "{{ insforge_slot }}"
  COSMO_ENDPOINT = "{{ cosmo_endpoint }}"
  GRAPHQL_PORT = "{{ graphql_port }}"
  COSIGN_EXPERIMENTAL = "1"
  COSIGN_CERT_IDENTITY = "https://github.com/nihalnihalani/understudy/.github/workflows/release.yml@refs/heads/main"
  COSIGN_CERT_OIDC_ISSUER = "https://token.actions.githubusercontent.com"
  AGENT_IMAGE_REF = "ghcr.io/nihalnihalani/understudy-agent-{{ agent_id }}@{{ image_digest }}"

[processes]
  agent = "/usr/local/bin/verify-self.sh python -m apps.agent_template.main"

[[vm]]
  size = "performance-2x"
  memory = "2gb"

[[services]]
  processes = ["agent"]
  internal_port = {{ graphql_port }}
  protocol = "tcp"
  auto_stop_machines = {% if pre_warm|default(false) %}"off"{% else %}true{% endif %}
  auto_start_machines = true
  min_machines_running = {% if pre_warm|default(false) %}1{% else %}0{% endif %}

  [[services.ports]]
    port = 443
    handlers = ["tls", "http"]

  [[services.http_checks]]
    interval = "15s"
    timeout = "5s"
    grace_period = "20s"
    method = "POST"
    path = "/graphql"
    protocol = "http"
    [services.http_checks.headers]
      Content-Type = "application/json"

{
  "name": "understudy",
  "version": "0.1.0",
  "private": true,
  "description": "Understudy monorepo — JS/TS workspaces for generated agent template and future web UI.",
  "workspaces": [
    "apps/agent-template",
    "apps/web"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "typecheck": "npm --workspace apps/web run typecheck",
    "lint": "npm --workspace apps/web run lint"
  },
  "engines": {
    "node": ">=20"
  }
}
